name: Telegram + Gemini Daily Post

on:
  schedule:
    - cron: '18 21 * * *'  # 21:18 MSK

jobs:
  post:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v3
      
      - name: Set up Python
        uses: actions/setup-python@v4
        with:
          python-version: '3.11'
      
      - name: Install dependencies
        run: |
          pip install google-genai requests
      
      - name: Create script
        run: |
          cat > telegram_gemini_autopost.py << 'EOF'
          import time
          from datetime import datetime
          from google import genai
          import requests
          
          TELEGRAM_BOT_TOKEN = "8768240870:AAFP75AHq0_Mhrf9S-AMYfjIBUrCoUo7lfY"
          GEMINI_API_KEY = "AQ.Ab8RN6L0T7tOOeKnSAsCge8GsznAyNC1wGEw0GvIkomPf8yeeg"
          TG_CHANNEL_ID = "-1003719924718"
          BASE_PROMPT = "Какой сегодня день месяца? Сегодня {} число."
          GEMINI_MODEL = "gemini-3.5-flash"
          
          def get_gemini_response(day_number: int) -> str:
              prompt = BASE_PROMPT.format(day_number)
              client = genai.Client(api_key=GEMINI_API_KEY)
              response = client.models.generate_content(
                  model=GEMINI_MODEL,
                  contents=prompt
              )
              return response.text
          
          def send_to_telegram(text: str) -> bool:
              url = f"https://api.telegram.org/bot{TELEGRAM_BOT_TOKEN}/sendMessage"
              response = requests.post(url, data={
                  "chat_id": TG_CHANNEL_ID,
                  "text": text
              })
              return response.status_code == 200
          
          def get_current_day_number() -> int:
              return datetime.now().day
          
          def daily_posting_job() -> None:
              day_number = get_current_day_number()
              gemini_answer = get_gemini_response(day_number)
              post_text = f"🗓 **Ежедневный отчет - {day_number} число**\n\n{gemini_answer}"
              send_to_telegram(post_text)
          
          daily_posting_job()
          EOF
          
      - name: Run script
        env:
          TELEGRAM_BOT_TOKEN: ${{ secrets.TELEGRAM_BOT_TOKEN }}
          GEMINI_API_KEY: ${{ secrets.GEMINI_API_KEY }}
          TG_CHANNEL_ID: ${{ secrets.TG_CHANNEL_ID }}
        run: |
          python telegram_gemini_autopost.py
